FROM node:18-alpine

WORKDIR /app

# Простое приложение-заглушка
RUN echo '{"name":"frontend","version":"1.0.0","scripts":{"start":"npx http-server -p 5173"}}' > package.json

RUN npm install http-server

# Создаем простой index.html
RUN echo '<!DOCTYPE html><html><head><title>Marketplace</title></head><body><h1>Marketplace Frontend</h1><p>API доступен по адресу: <a href="http://localhost:8082">Backend</a></p></body></html>' > index.html

EXPOSE 5173

CMD ["npx", "http-server", "-p", "5173"]
